{
  "name": "renpy-agent",
  "version": "0.1.0",
  "description": "Agent pipeline: inspiration → playable Ren'Py galgame",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc && node scripts/copy-templates.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node --env-file=.env dist/cli.js"
  },
  "bin": {
    "renpy-agent": "dist/cli.js"
  },
  "keywords": [
    "renpy",
    "galgame",
    "agent"
  ],
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@anthropic-ai/bedrock-sdk": "^0.28.1",
    "@anthropic-ai/sdk": "^0.90.0",
    "dotenv": "^16.0.0"
  }
}
