# 复制一份到 .env 并填入真 key。.env 不会被提交。
#
# 本项目的门禁 smoke(scripts/v5-real-key-smoke.mjs)需要**下面四件套齐全**:
# CLAUDE_CODE_USE_BEDROCK / AWS_REGION / AWS_BEARER_TOKEN_BEDROCK / RUNNINGHUB_API_KEY。

# -------- Planner / Writer / Storyboarder LLM(Claude) --------
# 默认走 AWS Bedrock(推荐,符合本项目作者本机设定)。设为 1 即可。
CLAUDE_CODE_USE_BEDROCK=1
AWS_REGION=us-east-1
AWS_BEARER_TOKEN_BEDROCK=
# 可选:覆盖模型 ID。Bedrock 下默认用 us. 前缀的 inference profile
# (on-demand throughput 模型需要 profile ID,不接受裸 model ID)。
# CLAUDE_MODEL=us.anthropic.claude-sonnet-4-6

# 如果你想走 Anthropic 直连(api.anthropic.com),把 CLAUDE_CODE_USE_BEDROCK 注释掉或置空,
# 然后填下面这行:
# ANTHROPIC_API_KEY=

# -------- Prompt cache(默认开,无需配置) --------
# Bedrock 和直连都默认挂 cache_control,long-system prompt 会被 Anthropic 缓存
# (5 分钟 TTL),V5 流水线上单次跑预期省 40-60% input token。
# 遇到 cache 引起的异常(罕见,多为 region 不支持)时:
#   CLAUDE_BEDROCK_CACHE=0    # 只在 Bedrock 上关;direct 不受影响
#   CLAUDE_DISABLE_CACHE=1    # 双模式总开关,全关
# 验证当前 region 的 cache 行为:node --env-file=.env scripts/prompt-cache-probe.mjs

# -------- RunningHub(图 / 视频资产生成,v0.3 起启用) --------
RUNNINGHUB_API_KEY=

# -------- 其它候选 LLM(未来可切) --------
# GEMINI_API_KEY=
# OPENAI_API_KEY=
